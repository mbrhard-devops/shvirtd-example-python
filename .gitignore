# Папка с кешем байт-кода Python
__pycache__/

# Скомпилированные файлы Python (разные расширения)
*.pyc
*.pyo
*.pyd

# Ссылка на интерпретатор в venv
.Python

# Папки виртуальных окружений (разные варианты имен)
env/
venv/
ENV/
.venv/

# Информация об установленных пакетах
*.egg-info/
.eggs/

# Папка git (на всякий случай, если кто-то скопирует)
.git/

# Файлы с паролями, ключами, токенами
.env
.env.local
.env.*.local

# Файлы логов
*.log

# Временные папки
tmp/
temp/
